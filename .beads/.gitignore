# Beads-sync worktree .beads/.gitignore
# This worktree commits issues.jsonl, metadata.json, interactions.jsonl, config.yaml
# Root .gitignore handles the negation patterns

# SQLite databases
*.db
*.db?*
*.db-journal
*.db-wal
*.db-shm

# Daemon runtime files
daemon.lock
daemon.log
daemon.pid
bd.sock
.local_version

# Legacy database files
db.sqlite
bd.db

# Merge artifacts
beads.base.jsonl
beads.base.meta.json
beads.left.jsonl
beads.left.meta.json
beads.right.jsonl
beads.right.meta.json
sync-state.json
last-touched
