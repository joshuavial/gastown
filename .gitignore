# Beads-sync worktree gitignore
# This worktree commits the JSONL files that the main repo ignores

# Still ignore runtime state
.beads/redirect
.beads/mq/
.beads/last-touched
.beads/daemon-*.log.gz
.beads/.sync.lock
.beads/sync_base.jsonl
.beads/*.db
.beads/*.db-*
.beads/daemon.lock
.beads/daemon.log
.beads/daemon.pid
.beads/bd.sock

# Un-ignore the sync files (override parent gitignore)
!.beads/issues.jsonl
!.beads/interactions.jsonl
!.beads/metadata.json
!.beads/config.yaml
